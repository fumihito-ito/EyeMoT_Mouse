<Window x:Class="TobiiEyeMouse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tobii Eye Mouse — 視線マウス制御" Width="1200" Height="900"
        WindowState="Normal" ResizeMode="CanResize" WindowStartupLocation="CenterScreen"
        Background="#1E1E2E" Foreground="#F8FAFC"
        FontFamily="Segoe UI" FontSize="16"
        Loaded="Window_Loaded" Closing="Window_Closing">

    <Window.Resources>
        <!-- ジオメトリリソース -->
        <Geometry x:Key="IconMouse">M 12.5 1 C 8.35 1 5 4.35 5 8.5 V 15.5 C 5 19.64 8.35 23 12.5 23 C 16.64 23 20 19.64 20 15.5 V 8.5 C 20 4.35 16.64 1 12.5 1 Z M 12.5 3 C 15.54 3 18 5.46 18 8.5 V 10 H 7 V 8.5 C 7 5.46 9.46 3 12.5 3 Z M 12.5 5 C 11.66 5 11 5.66 11 6.5 V 8 H 14 V 6.5 C 14 5.66 13.34 5 12.5 5 Z M 7 12 H 18 V 15.5 C 18 18.53 15.54 21 12.5 21 C 9.46 21 7 18.53 7 15.5 Z</Geometry>
        <Geometry x:Key="IconEye">M 12 4.5 C 7 4.5 2.73 7.61 1 12 C 2.73 16.39 7 19.5 12 19.5 C 17 19.5 21.27 16.39 23 12 C 21.27 7.61 17 4.5 12 4.5 Z M 12 17 C 9.24 17 7 14.76 7 12 C 7 9.24 9.24 7 12 7 C 14.76 7 17 9.24 17 12 C 17 14.76 14.76 17 12 17 Z M 12 9 C 10.34 9 9 10.34 9 12 C 9 13.66 10.34 15 12 15 C 13.66 15 15 13.66 15 12 C 15 10.34 13.66 9 12 9 Z</Geometry>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#64748B"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" FontSize="17" Foreground="#93C5FD" Margin="0,0,0,4" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Margin" Value="0,6,15,6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Margin" Value="0,6,0,6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Margin" Value="10,6,10,6"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ボタン共通スタイル（丸みを帯びた大きなボタン） -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="55"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 注視クリック用ボタンスタイル（やや高さ抑えめ） -->
        <Style x:Key="DwellButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- ヘッダー用 -->
            <RowDefinition Height="*"/>
            <!-- メインコンテンツ用 -->
            <RowDefinition Height="Auto"/>
            <!-- アクションボタン用 -->
        </Grid.RowDefinitions>

        <!-- ヘッダー（固定） -->
        <Grid Grid.Row="0" Margin="16,12,16,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Tobii Eye Mouse — 視線制御パネル" FontSize="26" FontWeight="Bold" Foreground="#3B82F6"/>
                <TextBlock Text="視線でマウスカーソルを制御します。各項目を調整して使いやすく設定してください。" FontSize="14" Foreground="#E5E7EB" Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,16,0">
                <Border Background="#374151" CornerRadius="4" Padding="6,2" Margin="0,0,4,0" VerticalAlignment="Center">
                    <TextBlock Text="F5" FontWeight="Bold" Foreground="White" FontSize="13"/>
                </Border>
                <TextBlock Text="開始/停止" Foreground="#F3F4F6" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="13"/>
                <Border Background="#374151" CornerRadius="4" Padding="6,2" Margin="0,0,4,0" VerticalAlignment="Center">
                    <TextBlock Text="F6" FontWeight="Bold" Foreground="White" FontSize="13"/>
                </Border>
                <TextBlock Text="一時停止" Foreground="#F3F4F6" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="13"/>
                <Border Background="#374151" CornerRadius="4" Padding="6,2" Margin="0,0,4,0" VerticalAlignment="Center">
                    <TextBlock Text="Esc" FontWeight="Bold" Foreground="White" FontSize="13"/>
                </Border>
                <TextBlock Text="終了" Foreground="#F3F4F6" VerticalAlignment="Center" FontSize="13"/>
            </StackPanel>

            <!-- 最小化ボタン -->
            <StackPanel Grid.Column="2" Margin="12,0,6,0" VerticalAlignment="Center">
                <Button x:Name="BtnMinimize" Content="最小化" Style="{StaticResource ActionButtonStyle}" 
                        Width="220" FontSize="20" Padding="20,0" Background="#374151"
                        Click="BtnMinimize_Click" Margin="0"/>
                <TextBlock x:Name="TxtMinimizeHint" Text="注視/ホバーで最小化" Foreground="#D1D5DB" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,6,0,2"/>
            </StackPanel>
        </Grid>

        <!-- メインコンテンツ領域 (スクロールなし) -->
        <Grid Grid.Row="1" Margin="16,6,16,6">
            <Grid.ColumnDefinitions>
                <!-- 2カラムレイアウトで左右に均等配置 -->
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <!-- カラム間の隙間 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ＝＝＝ 左カラム ＝＝＝ -->
            <StackPanel Grid.Column="0">

                <!-- 接続情報 -->
                <GroupBox Header="接続情報">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Ellipse x:Name="StatusDot" Width="16" Height="16" Fill="Gray" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtStatus" Text="待機中" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtTrackerInfo" Text="トラッカー: ---" Foreground="#E5E7EB" FontSize="14"/>
                            <TextBlock x:Name="TxtScreenInfo" Text="画面: ---" Foreground="#E5E7EB" FontSize="14" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtGaze" Grid.Column="1" Text="" FontFamily="Consolas" FontSize="14" Foreground="#E5E7EB" VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>
                </GroupBox>

                <!-- 操作モード -->
                <GroupBox Header="操作モード">
                    <StackPanel>
                        <!-- 非表示のRadioButton（内部状態用） -->
                        <RadioButton x:Name="RbGazeUI" GroupName="Mode" IsChecked="True" Visibility="Collapsed"/>
                        <RadioButton x:Name="RbMouse" GroupName="Mode" Visibility="Collapsed"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnModeGazeUI" Grid.Column="0" Style="{StaticResource DwellButtonStyle}" Background="#3B82F6" Click="BtnModeGazeUI_Click" Height="48" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Path Data="{StaticResource IconEye}" Fill="White" Width="18" Height="18" Stretch="Uniform" Margin="0,0,8,0"/>
                                    <TextBlock Text="視線UIモード" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnModeMouse" Grid.Column="1" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Click="BtnModeMouse_Click" Height="48" Margin="4,0,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Path Data="{StaticResource IconMouse}" Fill="White" Width="18" Height="18" Stretch="Uniform" Margin="0,0,8,0"/>
                                    <TextBlock Text="マウスモード" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBlock x:Name="TxtModeDesc" Text="WPFのオーバーレイを使って快適に操作します。通常はこちらを使用。" Foreground="#E5E7EB" FontSize="13" Margin="0,4,0,2" TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>

                <!-- 注視イベント -->
                <GroupBox x:Name="GbDwell" Header="注視操作枠（Dwell Click）">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnDwellNone" Grid.Column="0" Content="なし" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Click="BtnDwellNone_Click" Margin="0,0,2,0"/>
                            <Button x:Name="BtnDwellSingle" Grid.Column="1" Content="クリック" Style="{StaticResource DwellButtonStyle}" Background="#3B82F6" Click="BtnDwellSingle_Click" Margin="2,0,2,0"/>
                            <Button x:Name="BtnDwellDouble" Grid.Column="2" Content="ダブルクリック" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Click="BtnDwellDouble_Click" Margin="2,0,2,0"/>
                            <Button x:Name="BtnDwellDrag" Grid.Column="3" Content="ドラッグ" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Click="BtnDwellDrag_Click" Margin="2,0,0,0"/>
                        </Grid>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="注視時間" VerticalAlignment="Center" FontSize="14"/>
                            <Button x:Name="BtnDwellTimeDec" Grid.Row="0" Grid.Column="1" Content="-" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnDwellTimeDec_Click"/>
                            <Slider x:Name="SlDwellTime" Grid.Row="0" Grid.Column="2" Minimum="200" Maximum="3000" Value="2000" TickFrequency="50" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
                            <Button x:Name="BtnDwellTimeInc" Grid.Row="0" Grid.Column="3" Content="+" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnDwellTimeInc_Click"/>
                            <TextBlock x:Name="TxtDwellTime" Grid.Row="0" Grid.Column="4" Text="2000 ms" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" TextAlignment="Right"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="判定半径" VerticalAlignment="Center" FontSize="14"/>
                            <Button x:Name="BtnDwellRadiusDec" Grid.Row="1" Grid.Column="1" Content="-" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnDwellRadiusDec_Click"/>
                            <Slider x:Name="SlDwellRadius" Grid.Row="1" Grid.Column="2" Minimum="10" Maximum="150" Value="50" TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
                            <Button x:Name="BtnDwellRadiusInc" Grid.Row="1" Grid.Column="3" Content="+" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnDwellRadiusInc_Click"/>
                            <TextBlock x:Name="TxtDwellRadius" Grid.Row="1" Grid.Column="4" Text="50 px" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" TextAlignment="Right"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="クールダウン" VerticalAlignment="Center" FontSize="14"/>
                            <Button x:Name="BtnDwellCoolDec" Grid.Row="2" Grid.Column="1" Content="-" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnDwellCoolDec_Click"/>
                            <Slider x:Name="SlDwellCool" Grid.Row="2" Grid.Column="2" Minimum="100" Maximum="2000" Value="1000" TickFrequency="50" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
                            <Button x:Name="BtnDwellCoolInc" Grid.Row="2" Grid.Column="3" Content="+" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnDwellCoolInc_Click"/>
                            <TextBlock x:Name="TxtDwellCool" Grid.Row="2" Grid.Column="4" Text="1000 ms" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <!-- ＝＝＝ 右カラム ＝＝＝ -->
            <StackPanel Grid.Column="2">

                <!-- フィルタ設定 -->
                <GroupBox Header="ブレ補正・フィルタ設定">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="応答性" VerticalAlignment="Center" FontSize="14"/>
                            <Button x:Name="BtnResponsiveDec" Grid.Row="0" Grid.Column="1" Content="-" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnResponsiveDec_Click"/>
                            <Slider x:Name="SlResponsive" Grid.Row="0" Grid.Column="2" Minimum="5" Maximum="100" Value="90" TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
                            <Button x:Name="BtnResponsiveInc" Grid.Row="0" Grid.Column="3" Content="+" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnResponsiveInc_Click"/>
                            <TextBlock x:Name="TxtResponsive" Grid.Row="0" Grid.Column="4" Text="90%" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" TextAlignment="Right"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="デッドゾーン" VerticalAlignment="Center" FontSize="14"/>
                            <Button x:Name="BtnDeadDec" Grid.Row="1" Grid.Column="1" Content="-" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnDeadDec_Click"/>
                            <Slider x:Name="SlDead" Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="60" Value="0" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
                            <Button x:Name="BtnDeadInc" Grid.Row="1" Grid.Column="3" Content="+" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnDeadInc_Click"/>
                            <TextBlock x:Name="TxtDead" Grid.Row="1" Grid.Column="4" Text="0 px" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" TextAlignment="Right"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="最大速度" VerticalAlignment="Center" FontSize="14"/>
                            <Button x:Name="BtnSpeedDec" Grid.Row="2" Grid.Column="1" Content="-" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnSpeedDec_Click"/>
                            <Slider x:Name="SlSpeed" Grid.Row="2" Grid.Column="2" Minimum="500" Maximum="15000" Value="5000" TickFrequency="100" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
                            <Button x:Name="BtnSpeedInc" Grid.Row="2" Grid.Column="3" Content="+" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnSpeedInc_Click"/>
                            <TextBlock x:Name="TxtSpeed" Grid.Row="2" Grid.Column="4" Text="5000" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" TextAlignment="Right"/>
                        </Grid>

                        <Button x:Name="BtnDirectToggle" Content="ダイレクトモード（フィルタなし・最速応答）"
                                Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Margin="0"
                                Foreground="#FECACA" Click="BtnDirectToggle_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- カーソル設定 -->
                <GroupBox Header="カーソル設定">
                    <StackPanel>
                        <UniformGrid Columns="3" Margin="0,0,0,8">
                            <Button x:Name="BtnCurNone" Content="∅" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Margin="2" Height="48" FontSize="22" Click="BtnCurStyle_Click"/>
                            <Button x:Name="BtnCurCross" Content="✚" Style="{StaticResource DwellButtonStyle}" Background="#3B82F6" Margin="2" Height="48" FontSize="22" Click="BtnCurStyle_Click"/>
                            <Button x:Name="BtnCurCircle" Content="●" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Margin="2" Height="48" FontSize="22" Click="BtnCurStyle_Click"/>
                            <Button x:Name="BtnCurDiamond" Content="◆" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Margin="2" Height="48" FontSize="22" Click="BtnCurStyle_Click"/>
                            <Button x:Name="BtnCurRing" Content="◎" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Margin="2" Height="48" FontSize="22" Click="BtnCurStyle_Click"/>
                            <Button x:Name="BtnCurDot" Content="⚫" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Margin="2" Height="48" FontSize="22" Click="BtnCurStyle_Click"/>
                        </UniformGrid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="カーソルサイズ" VerticalAlignment="Center" FontSize="14"/>
                            <Button x:Name="BtnCursorSizeDec" Grid.Column="1" Content="-" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnCursorSizeDec_Click"/>
                            <Slider x:Name="SlCursorSize" Grid.Column="2" Minimum="20" Maximum="200" Value="100" TickFrequency="4" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
                            <Button x:Name="BtnCursorSizeInc" Grid.Column="3" Content="+" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnCursorSizeInc_Click"/>
                            <TextBlock x:Name="TxtCursorSize" Grid.Column="4" Text="100 px" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- スクロール設定 -->
                <GroupBox Header="スクロール設定">
                    <StackPanel>
                        <Button x:Name="BtnScrollToggle" Content="画面上下端でのスクロール" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Margin="0,0,0,8" Click="BtnScrollToggle_Click"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="エッジ判定幅" VerticalAlignment="Center" FontSize="14"/>
                            <Button x:Name="BtnScrollEdgeDec" Grid.Row="0" Grid.Column="1" Content="-" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnScrollEdgeDec_Click"/>
                            <Slider x:Name="SlScrollEdge" Grid.Row="0" Grid.Column="2" Minimum="50" Maximum="400" Value="100" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
                            <Button x:Name="BtnScrollEdgeInc" Grid.Row="0" Grid.Column="3" Content="+" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnScrollEdgeInc_Click"/>
                            <TextBlock x:Name="TxtScrollEdge" Grid.Row="0" Grid.Column="4" Text="100 px" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" TextAlignment="Right"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="スクロール速度" VerticalAlignment="Center" FontSize="14"/>
                            <Button x:Name="BtnScrollSpeedDec" Grid.Row="1" Grid.Column="1" Content="-" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnScrollSpeedDec_Click"/>
                            <Slider x:Name="SlScrollSpeed" Grid.Row="1" Grid.Column="2" Minimum="1" Maximum="20" Value="3" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
                            <Button x:Name="BtnScrollSpeedInc" Grid.Row="1" Grid.Column="3" Content="+" Style="{StaticResource DwellButtonStyle}" Background="#4B5563" Width="30" Margin="2" Click="BtnScrollSpeedInc_Click"/>
                            <TextBlock x:Name="TxtScrollSpeed" Grid.Row="1" Grid.Column="4" Text="3" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </Grid>

        <!-- アクションボタン類（画面下部固定） -->
        <Grid Grid.Row="2" Margin="16,6,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <Button x:Name="BtnStart" Content="▶ 開始" Style="{StaticResource ActionButtonStyle}" 
                        Background="#10B981" Click="BtnStart_Click" Margin="0"/>
                <TextBlock x:Name="TxtStartHint" Text="注視/ホバーで開始" Foreground="#D1D5DB" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,4,0,2"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="8,0,8,0">
                <Button x:Name="BtnPause" Content="⏸ 一時停止" Style="{StaticResource ActionButtonStyle}" 
                        Background="#F59E0B" IsEnabled="False" Click="BtnPause_Click" Margin="0"/>
                <TextBlock x:Name="TxtPauseHint" Text="注視/ホバーで一時停止" Foreground="#D1D5DB" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,4,0,2"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                <!-- リセットボタンは視線ホバーで発火すると危険なのでそのまま、レイアウトだけ揃える -->
                <Button x:Name="BtnReset" Content="↺ リセット" Style="{StaticResource ActionButtonStyle}" 
                        FontSize="16" Background="#4B5563" Click="BtnReset_Click" Margin="0"/>
                <TextBlock Text="クリック操作のみ" Foreground="#9CA3AF" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,4,0,2"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
